# ============================================================
# Variáveis de ambiente do BuscaCentral
# ------------------------------------------------------------
# Copie este arquivo para `.env.local` e preencha com os valores reais.
# NUNCA faça commit do `.env.local` (já está no .gitignore).
# Estas chaves são usadas APENAS no servidor — não as exponha no client.
# ============================================================

# Token da API da Brapi (cotações da B3) — https://brapi.dev
BRAPI_TOKEN=

# Chave da NewsAPI (notícias financeiras) — https://newsapi.org
NEWSAPI_KEY=
